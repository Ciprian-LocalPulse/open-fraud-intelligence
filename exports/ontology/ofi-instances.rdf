    <rdf:type rdf:resource="https://open-fraud-intelligence.github.io/ontology#Technique"/>
    <rdfs:label xml:lang="en">Fake media-branded ads promoting fictitious investment platforms</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://open-fraud-intelligence.github.io/data#technique-whatsapp-0002">
    <rdf:type rdf:resource="https://open-fraud-intelligence.github.io/ontology#Technique"/>
    <rdfs:label xml:lang="en">Account-takeover smishing via emotional pretext and 2FA code phishing</rdfs:label>
