  <rdf:Description rdf:about="https://open-fraud-intelligence.github.io/ontology#relatedto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="ro">O campanie folosește una sau mai multe tehnici</rdfs:comment>
    <rdfs:comment xml:lang="ro">O campanie vizează un profil de victimă</rdfs:comment>
    <rdfs:comment xml:lang="ro">O campanie e operată de un actor</rdfs:comment>
    <rdfs:comment xml:lang="ro">O campanie utilizează infrastructură tehnică</rdfs:comment>
    <rdfs:comment xml:lang="ro">O campanie produce un outcome</rdfs:comment>
    <rdfs:comment xml:lang="ro">Un actor exploatează o platformă</rdfs:comment>
    <rdfs:comment xml:lang="ro">Un actor fură active</rdfs:comment>
    <rdfs:comment xml:lang="ro">O tehnică utilizează o platformă</rdfs:comment>
    <rdfs:comment xml:lang="ro">O tehnică vizează un tip de activ</rdfs:comment>
    <rdfs:comment xml:lang="ro">O tehnică implică o metodă de plată</rdfs:comment>
    <rdfs:comment xml:lang="ro">O victimă pierde active</rdfs:comment>
    <rdfs:comment xml:lang="ro">O victimă furnizează dovezi</rdfs:comment>
    <rdfs:comment xml:lang="ro">O dovadă documentează o campanie</rdfs:comment>
  </rdf:Description>
